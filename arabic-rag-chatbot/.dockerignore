# .dockerignore — Exclude from Docker build context

# Python virtual environments
venv/
.venv/
env/
ENV/

# Git
.git/
.gitignore
.gitmodules

# Development tooling
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# IDE / editor configs
.vscode/
.idea/
*.swp
*.swo
*~

# OS / misc
.DS_Store
*.log
logs/
temp_uploads/
scratch/
*.tmp

# Local database files (Qdrant local storage)
qdrant_local_db/
*.db
*.sqlite
*.sqlite3

# Documentation (keep only if needed in production; remove to shrink image)
*.md
!README.md

# Test files
test/
tests/
*.test.js
*.spec.js

# Docker-specific
docker-compose*.yml
Dockerfile.*

# Node modules (if any)
node_modules/

# Backup files
*.bak
*.backup

# Environment (sensitive — never copy into image)
.env
.env.*
!.env.example
