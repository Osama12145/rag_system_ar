# .env - Template
# انسخ هذا الملف إلى .env وملأ القيم الخاصة بك

# ========== OpenRouter API (للـ Models) ==========
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ========== Cohere API (للـ Embeddings) ==========
COHERE_API_KEY=your-cohere-api-key

# ========== Qdrant Vector Database ==========
# Locally: "local" (file-based in ./qdrant_local_db) or "http://localhost:6333"
# In Coolify: http://qdrant-eso00kc0k8ww0k4g00wkcw0g:6333
QDRANT_URL=local
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=company-documents

# ========== Database (PostgreSQL) ==========
# Use asyncpg driver: postgresql+asyncpg://...
# On Coolify: postgresql+asyncpg://postgres:PASSWORD@postgresql-database-xxxx:5432/chatbot_db
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/chatbot_db

# ========== LLM Settings ==========
LLM_MODEL=cohere/command-r7b-12-2024
TEMPERATURE=0.7
MAX_TOKENS=1500

# ========== RAG Settings ==========
TOP_K_DOCUMENTS=5
SIMILARITY_THRESHOLD=0.7
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ========== App Settings ==========
APP_NAME=Company Document Chatbot
DEBUG=False
LOG_LEVEL=INFO

# ========== Frontend Backend URL ==========
# Streamlit reads this to know where the API lives
# In Docker Compose: BACKEND_URL=http://api:8000
# In Coolify: set to your API service URL
BACKEND_URL=http://localhost:8000

# ========== CORS (للـ API) ==========
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501

# ========== Email Notifications (Optional) ==========
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-app-password

# ========== Monitoring (Sentry - Optional) ==========
SENTRY_DSN=https://your-sentry-dsn@sentry.io/123456

# ========== LangSmith Observability ==========
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=company-intelligence-rag
